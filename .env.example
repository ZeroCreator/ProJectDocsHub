# App
APP_NAME="ProJect Docs Hub"
PORT=8088

# Database (Docker uses /app/data/ path)
# Local: DATABASE_URL="sqlite+aiosqlite:///./projectdocs.db"
# Docker:  DATABASE_URL="sqlite+aiosqlite:///./data/projectdocs.db"
DATABASE_URL="sqlite+aiosqlite:///./data/projectdocs.db"

# Storage: local or s3
STORAGE_TYPE=local
# Local: LOCAL_STORAGE_PATH=./uploads
# Docker:  LOCAL_STORAGE_PATH=./data/uploads
LOCAL_STORAGE_PATH=./data/uploads

# ═══════════════════════════════════════════════════
# S3 settings (required if STORAGE_TYPE=s3)
# ═══════════════════════════════════════════════════

# Common settings
S3_BUCKET_NAME=my-docs-bucket
S3_ACCESS_KEY_ID=YOUR_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
S3_REGION=us-east-1

# Endpoint URL (leave empty for AWS S3)
# For Yandex Cloud: https://storage.yandexcloud.net
# For MinIO:        http://localhost:9000
# For Selectel:     https://s3.selcloud.ru
S3_ENDPOINT_URL=

# Force path-style URLs (required for MinIO and some self-hosted S3)
# AWS / Yandex / Selectel → False
# MinIO / Ceph / Garage   → True
S3_FORCE_PATH_STYLE=False

# Presigned URL lifetime in seconds (for private buckets)
S3_PRESIGNED_EXPIRES=3600
